# =========================================================
# SecKnow .gitignore
# ---------------------------------------------------------
# 说明：
# 1. 仅忽略本地开发、构建、缓存、运行时生成物
# 2. 不忽略源码、测试、脚本、配置模板、设计文档
# 3. 仅基于当前已明确的项目结构编写，不预设额外目录
# =========================================================


# =========================================================
# 1) 操作系统 / 编辑器临时文件
# =========================================================
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
Desktop.ini

.vscode/
.idea/

*.swp
*.swo
*~


# =========================================================
# 2) Python 缓存 / 虚拟环境 / 构建产物
# =========================================================
__pycache__/
*.py[cod]
*$py.class
*.pyc.*
*.py,cover

.python-version
.ipynb_checkpoints/

.venv/
venv/
env/
ENV/

.eggs/
*.egg
*.egg-info/
build/
dist/
pip-wheel-metadata/

.pytest_cache/
.mypy_cache/
.ruff_cache/
.pyre/
.hypothesis/
.nox/
.tox/


# =========================================================
# 3) 测试覆盖率 / 测试报告
# =========================================================
.coverage
.coverage.*
coverage.xml
htmlcov/
nosetests.xml
test-results/
coverage/


# =========================================================
# 4) 日志 / 运行时文件
# =========================================================
*.log
*.pid
*.seed
*.stackdump


# =========================================================
# 5) 前端依赖 / 构建缓存 / 测试产物
# =========================================================
node_modules/
frontend/node_modules/

frontend/dist/
frontend/.vite/
frontend/.cache/
frontend/.eslintcache
frontend/coverage/
frontend/playwright-report/
frontend/test-results/

*.tsbuildinfo


# =========================================================
# 6) 环境变量文件
# ---------------------------------------------------------
# 保留示例模板，忽略真实环境配置
# =========================================================
.env
.env.*
!.env.example
!.env.*.example


# =========================================================
# 7) 后端运行时目录
# ---------------------------------------------------------
# 仅忽略当前已明确约定的运行期目录。
# backend/src/secknow/ 下均为源码目录，不在此处忽略。
# =========================================================
backend/tmp/
backend/export/
backend/db/
backend/uploads/


# =========================================================
# 8) 本地数据库 / 检索索引文件
# ---------------------------------------------------------
# 忽略本地运行生成的数据库与向量检索索引文件
# =========================================================
db/

*.sqlite
*.sqlite3
*.db
*.duckdb
*.mdb
*.lmdb

*.faiss
*.index
*.idx
*.hnsw
*.npy
*.bin
*.parquet


# =========================================================
# 9) 文本处理 / 向量化中间结果文件
# ---------------------------------------------------------
# 仅忽略文件级中间产物，不预设额外目录名
# =========================================================
*.chunks.json
*.chunks.jsonl
*.processed.json
*.embeddings.json
*.embeddings.npy
*.parsed.txt
*.extracted.txt
*.ocr.json
*.ocr.txt


# =========================================================
# 10) 机器学习 / 模型缓存
# =========================================================
.cache/
.hf/
huggingface/
models/
checkpoints/
wandb/
mlruns/


# =========================================================
# 11) 离线包 / 发布产物
# =========================================================
offline_packages/
offline_build/
release/
releases/


# =========================================================
# 12) 杂项备份文件
# =========================================================
*.bak
*.tmp
*.orig
